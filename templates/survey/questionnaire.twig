<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{% if survey %}{{ survey.topic_name }}{% else %}Survey{% endif %}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; }
    header { background: #1e293b; color: white; padding: 20px 32px; text-align: center; }
    header h1 { font-size: 22px; }
    .container { max-width: 720px; margin: 40px auto; padding: 0 24px; }
    .question-card { background: white; border-radius: 12px; padding: 28px; margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.07); }
    .question-card h3 { font-size: 16px; color: #222; margin-bottom: 16px; }
    .option { display: block; padding: 12px 16px; border: 2px solid #e5e7eb; border-radius: 8px; margin-bottom: 10px; cursor: pointer; transition: all 0.2s; }
    .option:hover { border-color: #1e293b; background: #eef2ff; }
    input[type=radio] { margin-right: 10px; accent-color: #1e293b; }
    input[type=radio]:checked + span { color: #1e293b; font-weight: 600; }
    .submit-btn { width: 100%; padding: 16px; background: #1e293b; color: white; border: none; border-radius: 10px; font-size: 18px; font-weight: 600; cursor: pointer; margin-top: 10px; }
    .submit-btn:hover { background: #1e293b; }
    .message { text-align: center; padding: 60px 20px; }
    .message h2 { font-size: 28px; margin-bottom: 16px; }
    .score-box { display: inline-block; background: #1e293b; color: white; padding: 20px 40px; border-radius: 12px; font-size: 32px; font-weight: 700; margin: 16px 0; }
    .inactive-msg { color: #ef4444; font-size: 18px; }
  </style>
</head>
<body>
<header>
  <h1> {% if survey %}{{ survey.topic_name }}{% else %}Survey{% endif %}</h1>
</header>
<div class="container">

  {% if inactive %}
    <div class="message">
      <h2> Survey Unavailable</h2>
      <p class="inactive-msg">This survey is currently inactive or does not exist.</p>
    </div>

  {% elseif submitted %}
    <div class="message">
      <h2> Thank you for submitting!</h2>
      <div class="score-box">{{ score }} / {{ total }}</div>
      <p style="color:#555; margin-top:16px;">Your response has been recorded anonymously.</p>
    </div>

  {% else %}
    <form method="POST" action="/git_backend/survey_system/public/index.php/survey/{{ survey.unique_slug }}">
      {% for q in questions %}
      <div class="question-card">
        <h3>{{ loop.index }}. {{ q.question_text }}</h3>
        {% for option in q.options %}
        <label class="option">
          <input type="radio" name="q_{{ q.id }}" value="{{ option }}" required>
          <span>{{ option }}</span>
        </label>
        {% endfor %}
      </div>
      {% endfor %}
      <button class="submit-btn" type="submit">Submit Answers →</button>
    </form>
  {% endif %}

</div>
</body>
</html>